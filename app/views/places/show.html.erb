<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0"><%= @place["name"] %></h1>

  <% if @current_user != nil %>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">New Post</a>
  <% end %>
</div>

<div class="row g-4">
  <% for entry in @entries %>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <h3 class="card-title h5"><%= entry["title"] %></h3>
          <div class="text-muted mb-2"><%= entry["occurred_on"] %></div>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="mt-4">
  <a href="/places" class="btn btn-outline-secondary">Back to All Places</a>
</div>
