<div class="mb-4">
  <h1><%= @place["name"] %></h1>

  <% if @current_user != nil %>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">New Entry</a>
  <% end %>
</div>

<div class="row g-4">
  <% for entry in @entries %>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <% if entry.uploaded_image.attached? %>
            <img src="<%= url_for(entry.uploaded_image) %>" class="img-fluid mb-3" alt="<%= entry["title"] %>">
          <% end %>
          <h2 class="h5 card-title"><%= entry["title"] %></h2>
          <div class="text-muted mb-2"><%= entry["occurred_on"] %></div>
          <p class="card-text mb-0"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>
